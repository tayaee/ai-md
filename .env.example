# Reference only: these are the built-in defaults (see docker-compose.yml /
# engine/aimd/config.py). This file is NOT read automatically anymore.
# Pass real values as shell environment variables before `docker compose
# build`/`up`, e.g.: LLM_API_KEY=sk-xxxx LLM_MODEL=gpt-5.4 docker compose up -d
# See README.md "Quick Start" for a full example per provider.

LLM_API_KEY=your-key-here

LLM_BASE_URL=https://api.minimax.io/v1

LLM_MODEL=MiniMax-M3

LLM_MAX_TOKENS=200000

# `openai` or `claude`: `openai` by default
LLM_API_PROTOCOL=openai
